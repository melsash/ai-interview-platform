# ============================================================
# AI Interview Platform — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to git
# ============================================================

# ------ JWT ------
SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ------ Auth DB ------
AUTH_DB_USER=auth_user
AUTH_DB_PASSWORD=auth_pass
AUTH_DB_NAME=auth_db

# ------ Assessment DB ------
ASSESSMENT_DB_USER=assessment_user
ASSESSMENT_DB_PASSWORD=assessment_pass
ASSESSMENT_DB_NAME=assessment_db

# ------ AI DB ------
AI_DB_USER=ai_user
AI_DB_PASSWORD=ai_pass
AI_DB_NAME=ai_db

# ------ Redis ------
REDIS_PASSWORD=redis_pass

# ------ RabbitMQ ------
RABBITMQ_USER=rmq_user
RABBITMQ_PASSWORD=rmq_pass
RABBITMQ_VHOST=interview_vhost

# ------ OpenAI ------
OPENAI_API_KEY=sk-...

# ------ Email (Notification Service) ------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASSWORD=your-app-password
EMAILS_FROM=noreply@ai-interview.dev

# ------ Monitoring ------
GRAFANA_PASSWORD=grafana_pass

# ------ App ------
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=info
